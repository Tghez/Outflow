{
  "name": "@outflow/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "scrape": "tsx src/scripts/manual-scrape.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit migrate",
    "db:seed": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 tsx src/db/seed.ts",
    "db:seed-demo": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 tsx src/db/seed-demo.ts",
    "db:studio": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit studio"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@outflow/shared": "*",
    "@sergienko4/israeli-bank-scrapers": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.4.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "pino-pretty": "^13.1.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
