# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/outflow

# Security
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-char hex string>
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=<long random string>

# Server
PORT=3001
NODE_ENV=development

# Optional: scraper settings
SCRAPER_TIMEOUT_MS=120000

# AI / LLM (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MODEL_SMART=claude-sonnet-4-6

# LangSmith tracing (optional — https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=outflow
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
